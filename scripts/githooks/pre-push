#!/usr/bin/env bash
# Versioned pre-push gate installed through core.hooksPath.
#
# 1. Serialize same-repository pushes across worktrees.
# 2. Classify the union of paths in all pushed refs, fail-closed on any
#    malformed/unknown Git state, and run only relevant deterministic gates.
# 3. Run the path-scoped live grounding battery only by explicit opt-in.
#
# Environment:
#   MUSE_RUN_PREPUSH_GROUNDING=1  opt into the live-LLM grounding battery
#   MUSE_SKIP_PREPUSH=1           explicitly skip grounding (legacy compatible)
#   MUSE_SKIP_PREPUSH_ALL=1       emergency-only bypass of every stage
set -uo pipefail

# Git supplies four space-delimited ref fields per line. Capture this before
# any command can consume stdin; changed paths themselves are handled as NUL-
# delimited data below.
push_refs_stdin="$(cat)"
hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel)"

if [ "${MUSE_SKIP_PREPUSH_ALL:-0}" = "1" ]; then
  echo "pre-push: *** ALL stages skipped (MUSE_SKIP_PREPUSH_ALL=1) *** — emergency-only" >&2
  exit 0
fi

# shellcheck source=lib/pushlock.sh
source "$hook_dir/lib/pushlock.sh"
lockpath="$(pushlock_repo_target)" || {
  echo "pre-push: BLOCKED — could not resolve the shared push-lock path" >&2
  exit 1
}
pushlock_acquire "$lockpath" || exit 1
cd "$repo_root" || exit 1

zero_sha="0000000000000000000000000000000000000000"
empty_tree="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
scope_tmp="$(mktemp -d "${TMPDIR:-/tmp}/muse-prepush-scope.XXXXXX")" || {
  echo "pre-push: BLOCKED — could not create a temporary scope directory" >&2
  exit 1
}
seen_dir="$scope_tmp/seen"
mkdir "$seen_dir" || exit 1
changed_files=()
changed_file_count=0
scope_fallback=0
saw_ref=0
ref_index=0

add_changed_file() {
  local file="$1" key
  key="$(printf '%s' "$file" | git hash-object --stdin 2>/dev/null)" || return 1
  if [ ! -e "$seen_dir/$key" ]; then
    : > "$seen_dir/$key"
    changed_files[$changed_file_count]="$file"
    changed_file_count=$((changed_file_count + 1))
  fi
}

valid_sha() {
  [[ "$1" =~ ^[0-9a-fA-F]{40}$ ]]
}

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha extra; do
  [ -z "${local_ref:-}${local_sha:-}${remote_ref:-}${remote_sha:-}${extra:-}" ] && continue
  saw_ref=1
  ref_index=$((ref_index + 1))
  if [ -n "${extra:-}" ] || [ -z "${local_ref:-}" ] || [ -z "${local_sha:-}" ] \
    || [ -z "${remote_ref:-}" ] || [ -z "${remote_sha:-}" ] \
    || ! valid_sha "$local_sha" || ! valid_sha "$remote_sha"; then
    scope_fallback=1
    continue
  fi

  # Deleting a ref pushes no tree content.
  [ "$local_sha" = "$zero_sha" ] && continue

  local_commit="$(git rev-parse --verify "$local_sha^{commit}" 2>/dev/null)" || {
    scope_fallback=1
    continue
  }
  base="$empty_tree"
  if [ "$remote_sha" != "$zero_sha" ]; then
    base="$(git rev-parse --verify "$remote_sha^{commit}" 2>/dev/null)" || {
      scope_fallback=1
      continue
    }
  fi

  diff_file="$scope_tmp/diff.$ref_index"
  if ! git diff --name-only -z "$base" "$local_commit" > "$diff_file"; then
    scope_fallback=1
    continue
  fi
  while IFS= read -r -d '' file; do
    add_changed_file "$file" || scope_fallback=1
  done < "$diff_file"
done <<< "$push_refs_stdin"

# Direct invocation, malformed refs, missing objects, and diff failures all
# select the complete deterministic gate. An empty valid ref deletion does not.
[ "$saw_ref" -eq 0 ] && scope_fallback=1
rm -rf "$scope_tmp"

is_docs_or_asset_path() {
  case "$1" in
    docs/*|*.md|*.mdx|LICENSE|LICENSE.*|NOTICE|NOTICE.*|*.png|*.jpg|*.jpeg|*.gif|*.webp|*.svg) return 0 ;;
    *) return 1 ;;
  esac
}

is_web_impact_path() {
  case "$1" in
    apps/web/*|packages/shared/*|package.json|pnpm-lock.yaml|pnpm-workspace.yaml|tsconfig.json|tsconfig.base.json|vitest.shared.ts) return 0 ;;
    *) return 1 ;;
  esac
}

is_known_deterministic_path() {
  case "$1" in
    apps/*|packages/*|crates/*|scripts/*|harness/*|.github/workflows/*|package.json|pnpm-lock.yaml|pnpm-workspace.yaml|tsconfig.json|tsconfig.base.json|vitest.shared.ts|eslint.config.*) return 0 ;;
    *) return 1 ;;
  esac
}

is_full_lint_impact_path() {
  case "$1" in
    eslint.config.*|package.json|pnpm-lock.yaml|pnpm-workspace.yaml) return 0 ;;
    *) return 1 ;;
  esac
}

is_lintable_path() {
  case "$1" in
    *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs) return 0 ;;
    *) return 1 ;;
  esac
}

needs_deterministic="$scope_fallback"
needs_web="$scope_fallback"
needs_full_lint="$scope_fallback"
lint_files=()
lint_file_count=0
for ((index = 0; index < changed_file_count; index += 1)); do
  file="${changed_files[$index]}"
  if ! is_docs_or_asset_path "$file"; then
    needs_deterministic=1
    if ! is_known_deterministic_path "$file"; then
      needs_web=1
      needs_full_lint=1
    fi
  fi
  is_web_impact_path "$file" && needs_web=1
  is_full_lint_impact_path "$file" && needs_full_lint=1
  if [ -f "$file" ] && is_lintable_path "$file"; then
    lint_files[$lint_file_count]="$file"
    lint_file_count=$((lint_file_count + 1))
  fi
done

# Git GUI / IDE clients often omit version-manager paths.
resolve_pnpm() {
  command -v pnpm >/dev/null 2>&1 && return 0
  local nvmbin d
  for nvmbin in $(ls -dt "$HOME"/.nvm/versions/node/*/bin 2>/dev/null); do
    [ -x "$nvmbin/pnpm" ] && PATH="$nvmbin:$PATH" && break
  done
  for d in "$HOME/.local/share/pnpm" "$HOME/Library/pnpm" "$HOME/.volta/bin" "/opt/homebrew/bin" "/usr/local/bin"; do
    [ -x "$d/pnpm" ] && PATH="$d:$PATH"
  done
  command -v pnpm >/dev/null 2>&1
}

if [ "$needs_deterministic" -eq 0 ]; then
  echo "pre-push: deterministic gates skipped (docs/assets-only push)" >&2
elif ! resolve_pnpm; then
  echo "pre-push: BLOCKED — pnpm not found; deterministic gates are required for this push" >&2
  exit 1
else
  echo "pre-push: compile gate — pnpm -s typecheck:fast" >&2
  if ! pnpm -s typecheck:fast; then
    echo "pre-push: BLOCKED — typecheck:fast failed" >&2
    exit 1
  fi

  if [ "$needs_web" -eq 1 ]; then
    echo "pre-push: compile gate — apps/web typecheck (web-impacting push)" >&2
    if ! pnpm --filter @muse/web typecheck; then
      echo "pre-push: BLOCKED — apps/web typecheck failed. If a new test dependency is missing, run: pnpm install --frozen-lockfile" >&2
      exit 1
    fi
  else
    echo "pre-push: apps/web typecheck skipped (no web-impacting paths)" >&2
  fi

  if [ "$needs_full_lint" -eq 1 ]; then
    echo "pre-push: lint gate — pnpm -s lint (full fallback/config scope)" >&2
    if ! pnpm -s lint; then
      echo "pre-push: BLOCKED — lint failed" >&2
      exit 1
    fi
  elif [ "$lint_file_count" -gt 0 ]; then
    echo "pre-push: lint gate — $lint_file_count changed file(s)" >&2
    if ! pnpm -s exec eslint --cache --cache-location node_modules/.cache/eslint/ --cache-strategy content -- "${lint_files[@]}"; then
      echo "pre-push: BLOCKED — changed-file lint failed" >&2
      exit 1
    fi
  else
    echo "pre-push: lint skipped (no existing changed lintable files)" >&2
  fi
fi

if [ "${MUSE_SKIP_PREPUSH:-0}" = "1" ]; then
  echo "pre-push: grounding tripwire skipped (MUSE_SKIP_PREPUSH=1); deterministic gates were not skipped" >&2
  exit 0
fi

if [ "${MUSE_RUN_PREPUSH_GROUNDING:-0}" != "1" ]; then
  echo "pre-push: grounding tripwire skipped (opt in with MUSE_RUN_PREPUSH_GROUNDING=1)" >&2
  exit 0
fi

GROUNDING_PATH_PATTERNS=(
  "packages/agent-core/*"
  "packages/recall/*"
  "packages/prompts/*"
  "packages/model/*"
  "packages/autoconfigure/*"
  "apps/cli/src/*ask*"
  "apps/cli/src/*chat*"
  "apps/cli/src/*ground*"
  "apps/cli/src/*embed*"
  "apps/cli/scripts/verify-*.mjs"
  "scripts/eval-*"
  "scripts/precheck-grounding*"
)

file_matches_grounding_path() {
  local file="$1" pattern
  for pattern in "${GROUNDING_PATH_PATTERNS[@]}"; do
    case "$file" in
      $pattern) return 0 ;;
    esac
  done
  return 1
}

grounding_relevant="$scope_fallback"
for ((index = 0; index < changed_file_count; index += 1)); do
  file="${changed_files[$index]}"
  file_matches_grounding_path "$file" && grounding_relevant=1
done

if [ "$grounding_relevant" -eq 0 ]; then
  echo "pre-push: grounding tripwire skipped (no grounding-path changes in this push)" >&2
  exit 0
fi

if ! command -v pnpm >/dev/null 2>&1 && ! resolve_pnpm; then
  echo "pre-push: pnpm not on PATH — opt-in grounding tripwire skipped" >&2
  exit 0
fi

pnpm -s precheck:grounding
